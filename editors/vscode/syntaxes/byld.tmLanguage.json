{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Byld",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#colors"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#class-refs"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.byld",
          "match": "//.*$"
        },
        {
          "name": "comment.block.byld",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.byld",
          "match": "\\b(View|var|let|fn|inject|as|for|in|when|else|style|untrack|with|merge|use)\\b"
        },
        {
          "name": "keyword.other.byld",
          "match": "=>"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.byld",
          "match": "\\b(Int|Float|Bool|Str|List|Fn)\\b"
        }
      ]
    },
    "colors": {
      "patterns": [
        {
          "name": "constant.numeric.hex.color.byld",
          "match": "\\b0x[0-9a-fA-F]+\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.byld",
          "match": "\\b[0-9]+(\\.[0-9]+)?(deg|rad|ms)?\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.byld",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.byld",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.byld",
              "begin": "\\{",
              "end": "\\}",
              "patterns": [
                {
                  "include": "$self"
                }
              ]
            }
          ]
        }
      ]
    },
    "class-refs": {
      "patterns": [
        {
          "name": "entity.name.type.class.byld",
          "match": "\\.[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.class.byld",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        },
        {
          "name": "variable.other.byld",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  },
  "scopeName": "source.byld"
}
